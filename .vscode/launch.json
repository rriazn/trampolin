{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug App",
      "program": "${workspaceFolder}/src/app.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Unit Tests",
      "program": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": ["run", "tests/unit", "--pool=forks"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "smartStep": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API Tests",
      "program": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": ["run", "tests/api", "--pool=forks"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "smartStep": true
    }
  ]
}
