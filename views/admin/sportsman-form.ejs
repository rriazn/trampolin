<%- include('../partials/header', { title: sportsman ? 'Edit Athlete' : 'New Athlete', activePage: 'admin' }) %>
<div class="page-hero">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2" style="--bs-breadcrumb-divider-color:rgba(255,255,255,.5)">
        <li class="breadcrumb-item"><a href="/admin/sportsmen" class="text-white-50">Sportsmen</a></li>
        <li class="breadcrumb-item active text-white"><%= sportsman ? 'Edit' : 'New Athlete' %></li>
      </ol>
    </nav>
    <h1><i class="bi bi-person-<%= sportsman ? 'gear' : 'plus' %> me-2"></i><%= sportsman ? 'Edit Athlete' : 'New Athlete' %></h1>
  </div>
</div>
<div class="container">
<div class="row justify-content-center">
<div class="col-md-6">
<div class="card p-4">
<form method="POST" action="<%= action %>">
  <div class="mb-3">
    <label class="form-label small fw-600 text-muted text-uppercase">Full Name</label>
    <input type="text" name="name" class="form-control" value="<%= sportsman ? sportsman.name : '' %>" required>
  </div>
  <div class="mb-3">
    <label class="form-label small fw-600 text-muted text-uppercase">Club <span class="text-muted fw-normal">(optional)</span></label>
    <input type="text" name="club" class="form-control" value="<%= sportsman ? (sportsman.club || '') : '' %>">
  </div>
  <div class="mb-4">
    <label class="form-label small fw-600 text-muted text-uppercase">Category <span class="text-muted fw-normal">(optional)</span></label>
    <input type="text" name="category" class="form-control" value="<%= sportsman ? (sportsman.category || '') : '' %>" placeholder="e.g. Junior Men, Senior Women">
  </div>
  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-brand rounded-pill px-4"><i class="bi bi-check-lg me-1"></i><%= sportsman ? 'Save' : 'Create' %></button>
    <a href="/admin/sportsmen" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
  </div>
</form>
</div>
</div>
</div>
</div>
<%- include('../partials/footer') %>
