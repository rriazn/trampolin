<%- include('../partials/header', { title: round.name, activePage: 'scoring' }) %>
<div class="page-hero">
  <div class="container d-flex justify-content-between align-items-end">
    <div>
      <h1><i class="bi bi-pencil-square me-2"></i><%= round.name %></h1>
      <p><%= round.competition_name %></p>
    </div>
    <a href="/referee" class="btn btn-outline-light rounded-pill"><i class="bi bi-arrow-left me-1"></i>Back</a>
  </div>
</div>

<div class="container">
<% if (attempts.length === 0) { %>
<div class="card p-5 text-center text-muted">
  <i class="bi bi-exclamation-circle fs-1 mb-3 d-block" style="color:#b0b8d4"></i>
  <h5>No attempts set up yet</h5>
  <p class="mb-0 small">Ask the admin to create attempts for this round.</p>
</div>
<% } else { %>
<p class="text-muted small mb-3">
  <i class="bi bi-info-circle me-1"></i>
  Enter a score (0.0 – 10.0) and press Save. Re-submitting overwrites your previous score.
  <span class="ms-2 badge bg-success"><i class="bi bi-check me-1"></i>green = scored by you</span>
</p>
<div class="table-card card">
  <table class="table mb-0">
    <thead>
      <tr>
        <th style="width:60px">#</th>
        <th>Athlete</th>
        <th>Club</th>
        <th>Routine</th>
        <th style="width:80px" class="text-center">Attempt</th>
        <th style="width:220px">Your Score</th>
      </tr>
    </thead>
    <tbody>
    <% attempts.forEach(a => { %>
    <tr class="<%= a.my_score !== null ? 'table-success' : '' %>">
      <td><span class="badge bg-secondary rounded-pill"><%= a.start_order %></span></td>
      <td>
        <span class="fw-600"><%= a.sportsman_name %></span>
      </td>
      <td class="text-muted small"><%= a.club || '–' %></td>
      <td class="text-muted small"><%= a.routine || '–' %></td>
      <td class="text-center">
        <span class="badge rounded-pill bg-primary">#<%= a.attempt_number %></span>
      </td>
      <td>
        <form method="POST" action="/referee/score" class="d-flex gap-2 align-items-center">
          <input type="hidden" name="attemptId" value="<%= a.attempt_id %>">
          <input type="number" name="score" min="0" max="10" step="0.1"
                 value="<%= a.my_score !== null ? a.my_score.toFixed(1) : '' %>"
                 class="form-control form-control-sm" style="width:90px"
                 placeholder="0.0–10" required>
          <button class="btn btn-sm btn-brand rounded-pill"><i class="bi bi-check-lg"></i> Save</button>
          <% if (a.my_score !== null) { %>
          <span class="text-success fw-600 small"><i class="bi bi-check-circle-fill"></i> <%= a.my_score.toFixed(1) %></span>
          <% } %>
        </form>
      </td>
    </tr>
    <% }) %>
    </tbody>
  </table>
</div>
<% } %>
</div>
<%- include('../partials/footer') %>
