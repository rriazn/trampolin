<%- include('../partials/header', { title: 'Scoring', activePage: 'scoring' }) %>
<div class="page-hero">
  <div class="container">
    <h1><i class="bi bi-pencil-square me-2"></i>Scoring Dashboard</h1>
    <p>Select an active round to enter scores</p>
  </div>
</div>

<div class="container">
<% if (rounds.length === 0) { %>
<div class="card p-5 text-center text-muted">
  <i class="bi bi-hourglass-split fs-1 mb-3 d-block" style="color:#b0b8d4"></i>
  <h5>No active competitions right now</h5>
  <p class="mb-0 small">Check back when the admin activates a competition.</p>
</div>
<% } else { %>
<div class="row g-3">
  <% rounds.forEach(r => { %>
  <div class="col-md-6 col-lg-4">
    <a href="/referee/round/<%= r.id %>" class="text-decoration-none">
      <div class="card p-4 h-100" style="transition:.15s;cursor:pointer;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
        <div class="d-flex align-items-center gap-3">
          <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,var(--brand),#3a4080);display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="bi bi-flag-fill text-white fs-5"></i>
          </div>
          <div>
            <div class="fw-700"><%= r.name %></div>
            <div class="text-muted small"><%= r.competition_name %></div>
          </div>
          <i class="bi bi-chevron-right ms-auto text-muted"></i>
        </div>
      </div>
    </a>
  </div>
  <% }) %>
</div>
<% } %>
</div>
<%- include('../partials/footer') %>
