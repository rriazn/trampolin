<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %>Trampolin</title>
  <% if (typeof autoRefresh !== 'undefined' && autoRefresh) { %>
  <meta http-equiv="refresh" content="10">
  <% } %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body>
<% if (typeof hideNav === 'undefined' || !hideNav) { %>
<nav class="navbar navbar-main navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" href="/">🤸 Trampo<span class="dot">·</span>Score</a>
    <% if (currentUser) { %>
    <div class="d-flex align-items-center gap-3">
      <span class="nav-user-chip"><i class="bi bi-person-fill me-1"></i><%= currentUser.name %></span>
      <% if (currentUser.role === 'admin') { %>
      <a class="nav-link <%= typeof activePage !== 'undefined' && activePage==='admin' ? 'active' : '' %>" href="/admin"><i class="bi bi-gear-fill me-1"></i>Admin</a>
      <% } %>
      <a class="nav-link <%= typeof activePage !== 'undefined' && activePage==='scoring' ? 'active' : '' %>" href="/referee"><i class="bi bi-pencil-square me-1"></i>Scoring</a>
      <form method="POST" action="/logout" class="m-0">
        <button class="btn btn-sm btn-outline-light rounded-pill px-3">Logout</button>
      </form>
    </div>
    <% } %>
  </div>
</nav>
<% } %>

<% if (typeof flash !== 'undefined' && flash.success) { %>
<div class="container mt-3">
  <div class="alert flash-bar alert-success d-flex align-items-center gap-2" role="alert">
    <i class="bi bi-check-circle-fill"></i> <%= flash.success %>
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
  </div>
</div>
<% } %>
<% if (typeof flash !== 'undefined' && flash.error) { %>
<div class="container mt-3">
  <div class="alert flash-bar alert-danger d-flex align-items-center gap-2" role="alert">
    <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.error %>
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
  </div>
</div>
<% } %>
