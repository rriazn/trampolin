<%- include('../partials/header', { title: 'Athletes – ' + competition.name, activePage: 'admin' }) %>
<div class="page-hero">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2" style="--bs-breadcrumb-divider-color:rgba(255,255,255,.5); --bs-breadcrumb-item-active-color:#fff">
        <li class="breadcrumb-item"><a href="/admin/competitions" class="text-white-50">Competitions</a></li>
        <li class="breadcrumb-item"><a href="/admin/competitions/<%= competition.id %>/groups" class="text-white-50"><%= competition.name %></a></li>
        <li class="breadcrumb-item active text-white">Athletes</li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h1><i class="bi bi-people me-2"></i>Athletes</h1>
        <p><%= competition.name %></p>
      </div>
      <div class="d-flex gap-2">
        <button class="btn btn-outline-light rounded-pill" data-bs-toggle="collapse" data-bs-target="#uploadForm">
          <i class="bi bi-file-earmark-excel me-1"></i>Import Excel
        </button>
        <a href="/admin/competitions/<%= competition.id %>/sportsmen/export" class="btn btn-outline-light rounded-pill">
          <i class="bi bi-download me-1"></i>Export Excel
        </a>
        <a href="/admin/competitions/<%= competition.id %>/sportsmen/new" class="btn btn-accent rounded-pill">
          <i class="bi bi-plus-lg me-1"></i>Add Athlete
        </a>
      </div>
    </div>
  </div>
</div>

<div class="container">
  <div class="collapse mb-4" id="uploadForm">
    <div class="upload-panel">
      <h6 class="fw-700 mb-1"><i class="bi bi-cloud-upload me-2"></i>Import from Excel</h6>
      <p class="text-muted small mb-3">Required: <strong>Name</strong> &nbsp;·&nbsp; Optional: <strong>Club</strong>, <strong>Gender</strong>, <strong>Birthyear</strong>, <strong>Routine</strong></p>
      <form method="POST" action="/admin/competitions/<%= competition.id %>/sportsmen/upload" enctype="multipart/form-data" class="d-flex gap-2 align-items-center flex-wrap">
        <input type="file" name="file" class="form-control" accept=".xlsx,.xls,.ods,.csv" required style="max-width:320px">
        <button type="submit" class="btn btn-brand rounded-pill"><i class="bi bi-upload me-1"></i>Upload</button>
      </form>
    </div>
  </div>

  <% if (sportsmen.length === 0) { %>
  <div class="card p-4 text-center text-muted">
    <i class="bi bi-person-x fs-1 mb-2 d-block"></i>No athletes yet.
    <a href="/admin/competitions/<%= competition.id %>/sportsmen/new">Add one</a>.
  </div>
  <% } else { %>
  <div class="table-card card">
    <table class="table mb-0">
      <thead>
        <tr><th>Athlete</th><th>Club</th><th>Group</th><th>Gender</th><th>Birth Year</th><th>Routine</th><th></th></tr>
      </thead>
      <tbody>
      <% sportsmen.forEach(s => { %>
      <tr>
        <td class="fw-600"><i class="bi bi-person me-2 text-muted"></i><%= s.name %></td>
        <td><%- s.club || '<span class="text-muted">–</span>' %></td>
        <td>
          <% if (s.group_name) { %>
          <span class="badge rounded-pill bg-light text-dark border"><%= s.group_name %></span>
          <% } else { %><span class="text-muted">–</span><% } %>
        </td>
        <td><%- s.gender || '<span class="text-muted">–</span>' %></td>
        <td><%- s.birth_year || '<span class="text-muted">–</span>' %></td>
        <td><%- s.routine || '<span class="text-muted">–</span>' %></td>
        <td class="text-end">
          <a href="/admin/competitions/<%= competition.id %>/sportsmen/<%= s.id %>/edit" class="btn btn-sm btn-outline-secondary rounded-pill me-1">
            <i class="bi bi-pencil"></i>
          </a>
          <form method="POST" action="/admin/competitions/<%= competition.id %>/sportsmen/<%= s.id %>/delete" class="d-inline"
                onsubmit="return confirm('Delete <%= s.name %>?')">
            <button class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
