<%- include('../partials/header', { title: 'Competitions', activePage: 'admin' }) %>
<div class="page-hero">
  <div class="container d-flex justify-content-between align-items-center">
    <div>
      <h1><i class="bi bi-trophy me-2"></i>Competitions</h1>
      <p>Create and manage tournament events</p>
    </div>
    <a href="/admin/competitions/new" class="btn btn-accent rounded-pill"><i class="bi bi-plus-lg me-1"></i>New Competition</a>
  </div>
</div>

<div class="container">
  <div class="table-card card">
    <table class="table mb-0">
      <thead><tr><th>Name</th><th>Date</th><th>Status</th><th></th></tr></thead>
      <tbody>
      <% competitions.forEach(c => { %>
      <tr>
        <td class="fw-600"><%= c.name %></td>
        <td class="text-muted"><%= c.date || '–' %></td>
        <td><span class="badge rounded-pill status-<%= c.status %> px-3"><%= c.status %></span></td>
        <td class="text-end">
          <a href="/admin/competitions/<%= c.id %>/groups" class="btn btn-sm btn-brand rounded-pill me-1">
            <i class="bi bi-collection me-1"></i>Manage
          </a>
          <a href="/admin/competitions/<%= c.id %>/edit" class="btn btn-sm btn-outline-secondary rounded-pill me-1">
            <i class="bi bi-pencil"></i>
          </a>
          <% if (c.status === 'planned') { %>
          <form method="POST" action="/admin/competitions/<%= c.id %>/status" class="d-inline">
            <input type="hidden" name="status" value="active">
            <button class="btn btn-sm btn-success rounded-pill me-1"><i class="bi bi-play-fill me-1"></i>Activate</button>
          </form>
          <% } else if (c.status === 'active') { %>
          <form method="POST" action="/admin/competitions/<%= c.id %>/status" class="d-inline">
            <input type="hidden" name="status" value="closed">
            <button class="btn btn-sm btn-outline-secondary rounded-pill me-1"><i class="bi bi-stop-fill me-1"></i>Close</button>
          </form>
          <% } %>
          <form method="POST" action="/admin/competitions/<%= c.id %>/delete" class="d-inline"
                onsubmit="return confirm('Delete competition and ALL its data?')">
            <button class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
