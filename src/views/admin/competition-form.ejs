<%- include('../partials/header', { title: competition ? 'Edit Competition' : 'New Competition', activePage: 'admin' }) %>
<div class="page-hero">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2" style="--bs-breadcrumb-divider-color:rgba(255,255,255,.5)">
        <li class="breadcrumb-item"><a href="/admin/competitions" class="text-white-50">Competitions</a></li>
        <li class="breadcrumb-item active text-white"><%= competition ? 'Edit' : 'New Competition' %></li>
      </ol>
    </nav>
    <h1><i class="bi bi-trophy me-2"></i><%= competition ? 'Edit Competition' : 'New Competition' %></h1>
  </div>
</div>
<div class="container">
<div class="row justify-content-center">
<div class="col-md-6">
<div class="card p-4">
<form method="POST" action="<%= action %>">
  <div class="mb-3">
    <label class="form-label small fw-600 text-muted text-uppercase">Competition Name</label>
    <input type="text" name="name" class="form-control" value="<%= competition ? competition.name : '' %>" required placeholder="e.g. Spring Cup 2026">
  </div>
  <div class="mb-4">
    <label class="form-label small fw-600 text-muted text-uppercase">Date <span class="text-muted fw-normal">(optional)</span></label>
    <input type="date" name="date" class="form-control" value="<%= competition ? (competition.date || '') : '' %>">
  </div>
  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-brand rounded-pill px-4"><i class="bi bi-check-lg me-1"></i><%= competition ? 'Save' : 'Create' %></button>
    <a href="/admin/competitions" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
  </div>
</form>
</div>
</div>
</div>
</div>
<%- include('../partials/footer') %>
